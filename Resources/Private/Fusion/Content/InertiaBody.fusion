prototype(ZktSn0w.Inertia:InertiaBody) < prototype(Neos.Fusion:Component) {
  @propTypes {
    id = ${PropTypes.string}
    page = ${PropTypes.any}
  }

  id = "app"
  page = null

  renderer = Neos.Fusion:Tag {
    tagName = "div"
    attributes {
      id = ${props.id}
      data-page = ${Json.stringify(props.page)}
    }
  }
}
